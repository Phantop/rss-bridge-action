      <title>Magical Laws (And How To Break Them)</title>
      <link>https://www.scribblehub.com/series/1106565/magical-laws-and-how-to-break-them/</link>
      <guid isPermaLink="false">a93c2f99c8e140f9c73cabdbc87124275c25e9c4</guid>
